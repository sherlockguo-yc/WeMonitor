<!-- CI/CD 拓扑图 -->
<div class="card cicd-card">
  <div class="card-header">
    <div class="cicd-header-left">
      <svg class="cicd-header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="16,18 22,12 16,6"></polyline>
        <polyline points="8,6 2,12 8,18"></polyline>
      </svg>
      <h3>CI/CD 拓扑</h3>
    </div>
    <span class="status-badge" id="cicd-status-badge">加载中...</span>
  </div>
  <div class="card-body">
    <div id="cicd-diagram" class="nt-diagram">
      <div class="nt-loading">加载 CI/CD 拓扑...</div>
    </div>
    <div class="nt-legend">
      <!-- 状态色：节点边框与连线颜色共用以表示部署状态 -->
      <span class="nt-legend-item" title="节点最新、部署通道运行正常"><span class="nt-dot nt-dot-green"></span> 最新</span>
      <span class="nt-legend-item" title="存在可更新版本或正在部署中"><span class="nt-dot nt-dot-yellow"></span> 可更新/部署中</span>
      <span class="nt-legend-item" title="节点异常或服务已停止"><span class="nt-dot nt-dot-red"></span> 异常</span>
      <span class="nt-legend-item" title="状态未知或未获取到数据"><span class="nt-dot nt-dot-gray"></span> 未知</span>
      <span class="nt-legend-sep">|</span>
      <!-- 线型：表示数据流向的性质 -->
      <span class="nt-legend-item" title="代码与构建产物实际传输的部署通道，例如 repo→CI→Release→Deploy Agent→服务"><span class="nt-line-sample"></span> 实线：部署数据流</span>
      <span class="nt-legend-item" title="CI 构建完成后向 N150 发送的 webhook 触发通知，仅传递信号，不传输文件"><span class="nt-line-sample nt-line-dashed"></span> 虚线：CI 通知信号</span>
    </div>
  </div>
</div>

<section class="worker-summary-card card" id="worker-summary" aria-live="polite">
  <div class="worker-summary-head">
    <div>
      <div class="worker-summary-kicker">部署队列</div>
      <h3><i data-lucide="bot"></i> Queue Worker</h3>
    </div>
    <span class="worker-state-badge" id="worker-state-badge">加载中</span>
  </div>
  <div class="worker-summary-body" id="worker-summary-body">
    <span class="worker-summary-empty">正在读取 worker 状态...</span>
  </div>
</section>

<!-- 部署状态卡片 -->
<div class="deploy-grid" id="deploy-grid">
  <div class="empty-state">加载中...</div>
</div>

<script src="/js/cicd-topology.js?v=<%= version %>" defer></script>
<script src="/js/deploy.js?v<%= version %>" defer></script>
