<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — WeMonitor</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/style.css?v=<%= version %>">
  <link rel="stylesheet" href="/css/uPlot.min.css?v=<%= version %>">
  <script src="/js/uPlot.iife.min.js?v=<%= version %>" defer></script>
  <script src="/js/lucide.min.js?v=<%= version %>" defer></script>
  <script src="/js/common.js?v=<%= version %>" defer></script>
</head>
<body>
  <div class="app-layout">
    <!-- 侧栏 -->
    <aside class="sidebar">
      <div class="sidebar-brand">
        <span class="brand-icon"><i data-lucide="activity" class="icon-md"></i></span>
        <span class="brand-text">WeMonitor</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/" class="nav-item <%= active === 'dashboard' ? 'active' : '' %>">
          <i data-lucide="layout-dashboard" class="icon-sm"></i>
          <span>概览</span>
        </a>
        <%
          // 系统管理组是否展开：当前在 system / cron 页面时展开
          const adminGroupActive = ['system', 'cron'].includes(active);
        %>
        <div class="nav-group <%= adminGroupActive ? 'expanded' : '' %>" data-group="admin">
          <div class="nav-group-toggle" onclick="toggleNavGroup(this.parentElement)">
            <i data-lucide="server" class="icon-sm"></i>
            <span>系统管理</span>
            <i data-lucide="chevron-down" class="icon-sm nav-group-arrow"></i>
          </div>
          <div class="nav-group-items">
            <a href="/system" class="nav-sub-item <%= active === 'system' ? 'active' : '' %>">
              <i data-lucide="cpu" class="icon-sm"></i>
              <span>系统资源</span>
            </a>
            <a href="/cron" class="nav-sub-item <%= active === 'cron' ? 'active' : '' %>">
              <i data-lucide="clock" class="icon-sm"></i>
              <span>定时任务</span>
            </a>
          </div>
        </div>
        <%
          // 服务管理组是否展开：当前在 settings / services / deploy 任一页面时展开
          const svcGroupActive = ['settings', 'services', 'deploy', 'backup'].includes(active);
        %>
        <div class="nav-group <%= svcGroupActive ? 'expanded' : '' %>" data-group="services">
          <div class="nav-group-toggle" onclick="toggleNavGroup(this.parentElement)">
            <i data-lucide="settings" class="icon-sm"></i>
            <span>服务管理</span>
            <i data-lucide="chevron-down" class="icon-sm nav-group-arrow"></i>
          </div>
          <div class="nav-group-items">
            <a href="/settings" class="nav-sub-item <%= active === 'settings' ? 'active' : '' %>">
              <i data-lucide="sliders-horizontal" class="icon-sm"></i>
              <span>服务管理</span>
            </a>
            <a href="/services" class="nav-sub-item <%= active === 'services' ? 'active' : '' %>">
              <i data-lucide="activity" class="icon-sm"></i>
              <span>服务状态</span>
            </a>

            <a href="/backup" class="nav-sub-item <%= active === 'backup' ? 'active' : '' %>">
              <i data-lucide="database-backup" class="icon-sm"></i>
              <span>数据备份</span>
            </a>
            <a href="/deploy" class="nav-sub-item <%= active === 'deploy' ? 'active' : '' %>">
              <i data-lucide="rocket" class="icon-sm"></i>
              <span>CI/CD</span>
            </a>
          </div>
        </div>
        <%
          // 网络管理组是否展开：当前在 network / firewall / tunnel 任一页面时展开
          const netGroupActive = ['network', 'firewall', 'tunnel'].includes(active);
        %>
        <div class="nav-group <%= netGroupActive ? 'expanded' : '' %>" data-group="network">
          <div class="nav-group-toggle" onclick="toggleNavGroup(this.parentElement)">
            <i data-lucide="network" class="icon-sm"></i>
            <span>网络管理</span>
            <i data-lucide="chevron-down" class="icon-sm nav-group-arrow"></i>
          </div>
          <div class="nav-group-items">
            <a href="/network" class="nav-sub-item <%= active === 'network' ? 'active' : '' %>">
              <i data-lucide="globe" class="icon-sm"></i>
              <span>概览</span>
            </a>
            <a href="/firewall" class="nav-sub-item <%= active === 'firewall' ? 'active' : '' %>">
              <i data-lucide="shield" class="icon-sm"></i>
              <span>防火墙</span>
            </a>
            <a href="/tunnel" class="nav-sub-item <%= active === 'tunnel' ? 'active' : '' %>">
              <i data-lucide="orbit" class="icon-sm"></i>
              <span>Tunnel</span>
            </a>
          </div>
        </div>
        <% if (session.role === 'admin') { %>
        <a href="/users" class="nav-item <%= active === 'users' ? 'active' : '' %>">
          <i data-lucide="users" class="icon-sm"></i>
          <span>用户管理</span>
        </a>
        <% } %>
      </nav>
      <div class="sidebar-footer">
        <div class="sidebar-user">
          <span class="sidebar-username"><%= session.username || '用户' %></span>
          <a href="/logout" class="sidebar-logout" title="退出登录">退出</a>
        </div>
        <span class="sidebar-version" title="<%= version %>"><%= deployedAt %></span>
      </div>
    </aside>

    <!-- 主内容区 -->
    <main class="main-content">
      <header class="content-header">
        <h1 class="page-title"><%= title %></h1>
        <div class="header-actions">
          <button class="btn btn-secondary btn-sm" onclick="refreshData()" title="刷新数据">
            <i data-lucide="refresh-cw" class="icon-sm"></i>
          </button>
        </div>
      </header>
      <div class="content-body">
        <%- body %>
      </div>
    </main>
  </div>

  <script>
    function refreshData() {
      if (typeof refreshPage === 'function') refreshPage();
    }
    function toggleNavGroup(el) {
      el.classList.toggle('expanded');
    }
  </script>
  <script>
    if (typeof lucide !== 'undefined') lucide.createIcons();
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof lucide !== 'undefined') lucide.createIcons();
    });
  </script>
</body>
</html>
