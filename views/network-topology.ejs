<div class="card">
  <div class="card-header">
    <h3>网络拓扑</h3>
    <span class="status-badge" id="nt-status-badge">加载中...</span>
  </div>
  <div class="card-body">
    <div id="nt-diagram" class="nt-diagram">
      <div class="nt-loading">加载网络拓扑...</div>
    </div>
    <div class="nt-legend">
      <span class="nt-legend-item"><span class="nt-dot nt-dot-green"></span> 正常</span>
      <span class="nt-legend-item"><span class="nt-dot nt-dot-red"></span> 异常</span>
      <span class="nt-legend-item"><span class="nt-dot nt-dot-gray"></span> 未知</span>
      <span class="nt-legend-sep">|</span>
      <span class="nt-legend-item"><span class="nt-line-sample nt-line-gray"></span> 默认</span>
      <span class="nt-legend-item"><span class="nt-line-sample"></span> 在线</span>
      <span class="nt-legend-item"><span class="nt-line-sample nt-line-red"></span> 异常</span>
      <span class="nt-legend-sep">|</span>
      <span class="nt-legend-item"><span class="nt-line-sample"></span> 实线</span>
      <span class="nt-legend-item"><span class="nt-line-sample nt-line-dashed"></span> 虚线</span>
    </div>
  </div>
</div>

