<div class="card" id="topology-view">
  <div class="card-header">
    <h3>网络拓扑</h3>
    <span class="status-badge" id="nt-status-badge">加载中...</span>
    <button class="btn btn-sm" onclick="switchToEditor()" style="margin-left:auto">编辑拓扑</button>
  </div>
  <div class="card-body">
    <div id="nt-diagram" class="nt-diagram">
      <div class="nt-loading">加载网络拓扑...</div>
    </div>
    <div class="nt-legend">
      <span class="nt-legend-item" title="节点运行正常"><span class="nt-dot nt-dot-green"></span> 正常</span>
      <span class="nt-legend-item" title="节点异常或服务中断"><span class="nt-dot nt-dot-red"></span> 异常</span>
      <span class="nt-legend-item" title="状态未知或未获取到数据"><span class="nt-dot nt-dot-gray"></span> 未知</span>
      <span class="nt-legend-sep">|</span>
      <span class="nt-legend-item" title="链路状态未检测"><span class="nt-line-sample nt-line-gray"></span> 未检测</span>
      <span class="nt-legend-item" title="链路正常可达"><span class="nt-line-sample nt-line-green"></span> 在线</span>
      <span class="nt-legend-item" title="链路中断或异常"><span class="nt-line-sample nt-line-red"></span> 异常</span>
      <span class="nt-legend-sep">|</span>
      <span class="nt-legend-item" title="实线：实际网络链路"><span class="nt-line-sample"></span> 实线：实际网络链路</span>
    </div>
  </div>
</div>

<div class="card" id="editor-card" style="display:none">
  <div class="card-header">
    <h3>拓扑编辑器</h3>
    <button class="btn btn-sm" onclick="switchToView()" style="margin-left:auto">← 返回概览</button>
  </div>
  <div class="card-body" style="padding:0">
    <div id="topology-editor-root" style="height:75vh;width:100%"></div>
  </div>
</div>

<div class="card" id="info-cards">
  <div class="card-header"><h3>流量路径说明</h3></div>
  <div class="card-body">
    <table class="data-table">
      <thead><tr><th>访问方式</th><th>路径</th><th>说明</th></tr></thead>
      <tbody>
        <tr><td>公网（域名）</td><td>Internet → CF CDN → CF Tunnel → N150</td><td>外部用户访问域名，经 Cloudflare CDN + Tunnel 到达 N150，<strong>不经过家庭网络</strong></td></tr>
        <tr><td>局域网（IP）</td><td>手机/电脑 → 路由器 → UFW → N150</td><td>同局域网下通过 N150 内网 IP 直接访问服务</td></tr>
        <tr><td>N150 出站</td><td>N150 → 路由器 → 光猫 → ISP → Internet</td><td>N150 主动出站到公网（建立 CF Tunnel、系统更新）</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- toggle 函数必须在 editor.js 之前定义，避免编辑器脚本加载失败导致函数未定义 -->
<script>
  var _editorReady = false;

  function switchToEditor() {
    document.getElementById('topology-view').style.display = 'none';
    document.getElementById('info-cards').style.display = 'none';
    var ec = document.getElementById('editor-card');
    ec.style.display = '';

    var root = document.getElementById('topology-editor-root');
    if (_editorReady && window.mountTopologyEditor) {
      if (!window._editorMounted) {
        try {
          window.mountTopologyEditor('topology-editor-root');
          window._editorMounted = true;
        } catch(e) {
          root.innerHTML = '<div style="padding:40px;text-align:center;color:var(--danger)">编辑器启动失败: ' + e.message + '</div>';
        }
      }
    } else {
      root.innerHTML = '<div style="padding:40px;text-align:center;color:var(--text-dim)">编辑器加载中...<br><small style="opacity:0.6">如长时间无响应，请刷新页面</small></div>';
    }
  }

  function switchToView() {
    document.getElementById('editor-card').style.display = 'none';
    document.getElementById('topology-view').style.display = '';
    document.getElementById('info-cards').style.display = '';
    refreshPage();
  }
</script>

<link rel="stylesheet" href="/topology-editor/wemonitor.css?v=<%= version %>">
<script src="/topology-editor/editor.js?v=<%= version %>" defer onload="_editorReady=true" onerror="document.getElementById('topology-editor-root').innerHTML='<div style=padding:40px;text-align:center;color:var(--danger)>编辑器脚本加载失败，请检查部署是否完整</div>'"></script>
<script src="/js/network-topology.js?v=<%= version %>" defer></script>
