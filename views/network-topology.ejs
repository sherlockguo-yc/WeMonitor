<div class="card">
  <div class="card-header">
    <h3>网络拓扑</h3>
    <span class="status-badge" id="nt-status-badge">加载中...</span>
  </div>
  <div class="card-body">
    <div id="nt-diagram" class="nt-diagram">
      <div class="nt-loading">加载网络拓扑...</div>
    </div>
    <div class="nt-legend">
      <!-- 节点状态色 -->
      <span class="nt-legend-item" title="节点运行正常"><span class="nt-dot nt-dot-green"></span> 正常</span>
      <span class="nt-legend-item" title="节点异常或服务中断"><span class="nt-dot nt-dot-red"></span> 异常</span>
      <span class="nt-legend-item" title="状态未知或未获取到数据"><span class="nt-dot nt-dot-gray"></span> 未知</span>
      <span class="nt-legend-sep">|</span>
      <!-- 连线状态色 -->
      <span class="nt-legend-item" title="链路状态未检测"><span class="nt-line-sample nt-line-gray"></span> 未检测</span>
      <span class="nt-legend-item" title="链路正常可达"><span class="nt-line-sample nt-line-green"></span> 在线</span>
      <span class="nt-legend-item" title="链路中断或异常"><span class="nt-line-sample nt-line-red"></span> 异常</span>
      <span class="nt-legend-sep">|</span>
      <!-- 线型含义 -->
      <span class="nt-legend-item" title="公网/内网实际可达的网络链路，如 Internet→光猫→路由器→CDN→Tunnel、UFW→直连服务"><span class="nt-line-sample"></span> 实线：实际网络链路</span>
      <span class="nt-legend-item" title="Cloudflare Tunnel 通过同一条隧道按域名分流到各内部服务，属于逻辑虚拟路由"><span class="nt-line-sample nt-line-dashed"></span> 虚线：Tunnel 虚拟路由</span>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3>流量路径说明</h3>
  </div>
  <div class="card-body">
    <table class="data-table">
      <thead>
        <tr><th>域名</th><th>入口</th><th>目标服务</th><th>端口</th></tr>
      </thead>
      <tbody>
        <tr><td>wemusic.sherlockguo.com</td><td>Cloudflare CDN</td><td>Cloudflare Tunnel → WeMusic</td><td>→ 5174</td></tr>
        <tr><td>wemonitor.sherlockguo.com</td><td>Cloudflare CDN</td><td>Cloudflare Tunnel → WeMonitor</td><td>→ 18990</td></tr>
        <tr><td>wedownload.sherlockguo.com</td><td>Cloudflare CDN</td><td>Cloudflare Tunnel → WeDownload</td><td>→ 8080</td></tr>
        <tr><td>wemusic.sherlockguo.com/deploy</td><td>Cloudflare CDN</td><td>Cloudflare Tunnel → Webhook</td><td>→ 9001</td></tr>
        <tr><td>直连 IP</td><td>UFW 防火墙</td><td>SSH / NPM Admin</td><td>22 / 8443</td></tr>
      </tbody>
    </table>
  </div>
</div>

