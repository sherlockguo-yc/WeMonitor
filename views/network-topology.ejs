<div class="card">
  <div class="card-header">
    <h3>网络拓扑</h3>
    <span class="status-badge" id="nt-status-badge">加载中...</span>
  </div>
  <div class="card-body">
    <div id="nt-diagram" class="nt-diagram">
      <div class="nt-loading">加载网络拓扑...</div>
    </div>
    <div class="nt-legend">
      <!-- 节点状态色 -->
      <span class="nt-legend-item" title="节点运行正常"><span class="nt-dot nt-dot-green"></span> 正常</span>
      <span class="nt-legend-item" title="节点异常或服务中断"><span class="nt-dot nt-dot-red"></span> 异常</span>
      <span class="nt-legend-item" title="状态未知或未获取到数据"><span class="nt-dot nt-dot-gray"></span> 未知</span>
      <span class="nt-legend-sep">|</span>
      <!-- 连线状态色 -->
      <span class="nt-legend-item" title="链路状态未检测"><span class="nt-line-sample nt-line-gray"></span> 未检测</span>
      <span class="nt-legend-item" title="链路正常可达"><span class="nt-line-sample nt-line-green"></span> 在线</span>
      <span class="nt-legend-item" title="链路中断或异常"><span class="nt-line-sample nt-line-red"></span> 异常</span>
      <span class="nt-legend-sep">|</span>
      <!-- 线型含义 -->
      <span class="nt-legend-item" title="Internet → ISP → 光猫 → 路由器 → CF CDN → CF Tunnel → N150 → 服务（公网路径），或 本地设备 → 路由器 → UFW → N150 → 服务（局域网路径）"><span class="nt-line-sample"></span> 实线：实际网络链路</span>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3>流量路径说明</h3>
  </div>
  <div class="card-body">
    <table class="data-table">
      <thead>
        <tr><th>访问方式</th><th>路径</th><th>端口</th></tr>
      </thead>
      <tbody>
        <tr><td>公网（域名）</td><td>Internet → ISP → 光猫 → 路由器 → CF CDN → Tunnel → N150 → 服务</td><td>各域名的 443（CDN 处理）</td></tr>
        <tr><td>公网 — wemusic</td><td>… → Tunnel → N150</td><td>→ 5174</td></tr>
        <tr><td>公网 — wemonitor</td><td>… → Tunnel → N150</td><td>→ 18990</td></tr>
        <tr><td>公网 — wedownload</td><td>… → Tunnel → N150</td><td>→ 8080</td></tr>
        <tr><td>公网 — webhook</td><td>… → Tunnel（/deploy）→ N150</td><td>→ 9001</td></tr>
        <tr><td>公网 — SSH</td><td>… → Tunnel → N150</td><td>→ 22（Zero Trust）</td></tr>
        <tr><td>局域网（IP 直连）</td><td>手机/电脑 → 路由器 → UFW → N150 → 服务</td><td>192.168.31.102:port</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script src="/js/network-topology.js?v=<%= version %>" defer></script>
