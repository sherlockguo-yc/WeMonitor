<div class="card">
  <div class="card-header">
    <h3>R2 备份管理</h3>
    <span style="font-size: calc(var(--font-size) * 0.85); color: var(--text-dim);">
      存储桶 n150-backups · 免费额度 10GB · 每天 03:00 自动备份
    </span>
  </div>
  <div class="card-body">
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>服务名</th>
            <th>备份状态</th>
            <th>上次备份</th>
            <th>大小</th>
            <th>R2 路径</th>
          </tr>
        </thead>
        <tbody id="backup-services-body">
          <tr><td colspan="5" class="empty-state">加载中...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
<script src="/js/backup.js?v=<%= version %>" defer></script>
