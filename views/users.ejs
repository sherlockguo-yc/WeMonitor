<div class="card">
  <div class="card-header">
    <h3>用户管理</h3>
  </div>
  <div class="card-body">
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>用户名</th>
            <th>角色</th>
            <th>状态</th>
            <th>注册时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody id="users-body">
          <tr><td colspan="5" class="empty-state">加载中...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>window.CURRENT_USER_ID = <%= session.userId %>;</script>
<script src="/js/users.js?v=<%= version %>" defer></script>
