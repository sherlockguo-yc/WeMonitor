<div class="card">
  <div class="card-header">
    <h3>Cloudflare Tunnel 状态</h3>
    <span class="status-badge" id="tunnel-status-badge">加载中...</span>
  </div>
  <div class="card-body">
    <div class="stats-grid" id="tunnel-stats">
      <div class="stat-item">
        <div class="stat-label">Tunnel 名称</div>
        <div class="stat-value" id="tunnel-name">--</div>
      </div>
      <div class="stat-item">
        <div class="stat-label">活跃连接</div>
        <div class="stat-value" id="tunnel-connections">--</div>
      </div>
      <div class="stat-item">
        <div class="stat-label">边缘节点</div>
        <div class="stat-value" id="tunnel-locations">--</div>
      </div>
      <div class="stat-item">
        <div class="stat-label">运行时间</div>
        <div class="stat-value" id="tunnel-uptime">--</div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3>操作</h3>
  </div>
  <div class="card-body">
    <div class="actions-row">
      <button class="btn btn-primary btn-sm" onclick="restartTunnel()" id="btn-restart">
        <i data-lucide="refresh-cw" class="icon-sm"></i> 重启 Tunnel
      </button>
      <span class="action-hint" id="restart-result"></span>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3>添加子域名路由</h3>
  </div>
  <div class="card-body">
    <div class="form-inline">
      <div class="form-group" style="flex:1;">
        <input type="text" id="route-hostname" class="form-input" placeholder="blog.sherlockguo.com">
      </div>
      <button class="btn btn-primary btn-sm" onclick="addTunnelRoute()">
        <i data-lucide="plus" class="icon-sm"></i> 添加
      </button>
    </div>
    <span class="action-hint" id="route-result"></span>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3>子域名路由</h3>
    <button class="btn btn-secondary btn-sm" onclick="loadTunnelRoutes()">
      <i data-lucide="rotate-cw" class="icon-sm"></i> 刷新
    </button>
  </div>
  <div class="card-body">
    <div id="tunnel-routes-container">
      <div class="text-dim" style="padding:calc(var(--font-size)*2) 0;text-align:center;">加载中...</div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3>最近日志</h3>
    <button class="btn btn-secondary btn-sm" onclick="loadTunnelLogs()">
      <i data-lucide="rotate-cw" class="icon-sm"></i> 刷新
    </button>
  </div>
  <div class="card-body">
    <pre class="log-viewer" id="tunnel-logs">加载中...</pre>
  </div>
</div>

<script src="/js/tunnel.js?v=<%= version %>" defer></script>
