<div class="tab-bar">
  <button class="tab active" data-range="1h">1 小时</button>
  <button class="tab" data-range="6h">6 小时</button>
  <button class="tab" data-range="24h">24 小时</button>
  <button class="tab" data-range="7d">7 天</button>
</div>

<div class="card chart-card">
  <div class="chart-header"><h3>CPU 使用率</h3></div>
  <div class="chart-body"><canvas id="cpuChart" style="width:100%; height:260px;"></canvas></div>
</div>

<div class="card chart-card">
  <div class="chart-header"><h3>内存使用</h3></div>
  <div class="chart-body"><canvas id="memChart" style="width:100%; height:260px;"></canvas></div>
</div>

<div class="card chart-card">
  <div class="chart-header"><h3>磁盘使用率</h3></div>
  <div class="chart-body"><canvas id="diskChart" style="width:100%; height:260px;"></canvas></div>
</div>

<div class="card chart-card">
  <div class="chart-header"><h3>网络流量</h3></div>
  <div class="chart-body"><canvas id="netChart" style="width:100%; height:260px;"></canvas></div>
</div>

<script src="/js/system.js?v=<%= version %>" defer></script>
